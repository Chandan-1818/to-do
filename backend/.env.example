# ============================================================
# .env.example — copy this to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── MongoDB ─────────────────────────────────────────────────
# Local development:
MONGO_URI=mongodb://localhost:27017/todoapp
# MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/todoapp?retryWrites=true&w=majority

# ── Server ──────────────────────────────────────────────────
PORT=5000

# ── JWT — REQUIRED ──────────────────────────────────────────
# Generate a secure secret with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# The server will refuse to start if JWT_SECRET is not set.
JWT_SECRET=replace_this_with_a_64_byte_random_hex_string

# Token expiry (e.g. 7d, 24h, 30m)
JWT_EXPIRES_IN=7d

# ── CORS — Frontend origin(s) ───────────────────────────────
# localhost:3000 and localhost:5173 are always allowed in every environment.
#
# Set CLIENT_URL to your deployed frontend URL so the production backend
# accepts requests from it. Comma-separate multiple URLs if needed.
#
# Examples:
#   Single origin:   CLIENT_URL=https://to-do-six-chandan.vercel.app
#   Multiple:        CLIENT_URL=https://to-do-six-chandan.vercel.app,https://staging.example.com
#
# On Render, add this as an environment variable in the service dashboard
# (Environment → Add Environment Variable).
CLIENT_URL=https://to-do-six-chandan.vercel.app
